.hero-search
  width: 100%
  background: var(--hero-bg, #6f4ef6)
  color: white
  padding: clamp(40px, 6vw, 90px) clamp(16px, 4vw, 32px)

  &__container
    max-width: var(--inner-max-width, 1200px)
    margin: 0 auto
    display: flex
    flex-direction: column
    align-items: center
    text-align: center

  &__title
    margin: 0
    font-size: 36px
    line-height: 1.1
    font-weight: bold
    letter-spacing: -0.02em

    @media (max-width: 768px)
      font-size: 1.7rem

  &__subtitle
    margin-top: 18px
    max-width: 920px
    font-size: var(--subtitle-size, 15px)
    line-height: 1.6
    color: rgba(255,255,255,0.92)

    @media (max-width: 768px)
      margin-top: 14px
      font-size: 0.95rem
      line-height: 1.5
      max-width: 760px

  &__box
    position: relative
    width: 760px
    margin-top: 50px
    display: flex
    align-items: center
    gap: 10px
    border-bottom: 1px solid rgba(255,255,255,0.55)

    @media (max-width: 768px)
      margin-top: 30px
      width: min(100%, 560px)

    @media (max-width: 640px)
      width: 100%
      gap: 10px

  &__caret
    position: absolute
    left: 10px
    bottom: 18px
    width: 2px
    height: 26px
    background: rgba(255,255,255,0.95)
    pointer-events: none
    transition: opacity 0.1s

    &.is-hidden
      opacity: 0

    &.is-blink
      animation: blink 1s step-end infinite

  &__input
    flex: 1
    min-width: 0
    background: transparent
    outline: none
    border: none
    color: white
    font-size: 18px
    font-weight: bold
    padding-left: 10px

    &::placeholder
      color: rgba(255,255,255,0.7)
      font-weight: normal

    @media (max-width: 768px)
      font-size: 16px

    @media (max-width: 640px)
      font-size: 15px
      padding-left: 24px

  &__button
    width: 40px
    height: 40px
    display: flex
    align-items: center
    justify-content: center
    color: white
    background: none
    border: none
    cursor: pointer
    transition: transform 0.2s ease

    &:hover:not(:disabled)
      transform: translateY(-1px)

    &:disabled
      opacity: 0.55
      cursor: not-allowed

    @media (max-width: 768px)
      width: 50px
      height: 50px

    @media (max-width: 640px)
      width: 44px
      height: 44px

  &__chips
    margin-top: 34px
    display: flex
    flex-wrap: wrap
    justify-content: center
    gap: 10px
    width: 100%

    @media (max-width: 768px)
      margin-top: 28px

    @media (max-width: 640px)
      gap: 8px
      margin-top: 24px

  &__chip
    background: rgba(255,255,255,0.3)
    border: 1px solid rgba(255,255,255,0.75)
    color: white
    font-size: 14px
    padding: 6px 12px
    border-radius: 8px
    line-height: 1
    cursor: pointer
    transition: all 0.2s ease

    &:hover
      background: rgba(255,255,255,0.1)
      transform: translateY(-1px)

    @media (max-width: 640px)
      font-size: 13px
      padding: 5px 10px

@keyframes blink
  0%, 49%
    opacity: 1
  50%, 100%
    opacity: 0