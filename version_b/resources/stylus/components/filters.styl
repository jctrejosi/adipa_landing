.filters
  font-size: 13px
  @media (min-width: 768px)
    font-size: 14px

  &__mobile
    display: flex
    flex-direction: column
    gap: 8px
    margin-bottom: 16px

  &__dropdown
    position: relative
    &-trigger
      width: 100%
      display: flex
      justify-content: space-between
      align-items: center
      background: white
      border: 1px solid #d1d5db
      border-radius: 6px
      padding: 8px 12px
      font-weight: 500
      color: var(--text-color, #13013f)
      cursor: pointer
      .dark &
        background: #1f2937
        border-color: #4b5563
        color: #f3f4f6
    &-panel
      position: absolute
      top: 100%
      left: 0
      width: 100%
      margin-top: 4px
      background: white
      border: 1px solid #e5e7eb
      border-radius: 8px
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)
      z-index: 20
      .dark &
        background: #1f2937
        border-color: #4b5563

  &__desktop
    .filters__rankings
      margin-bottom: 20px
    .filters__header
      display: flex
      justify-content: space-between
      align-items: center
      margin-bottom: 12px
      h4
        margin: 0
        font-weight: 600
        color: var(--text-color, #13013f)
        .dark &
          color: #f3f4f6
    .filters__clear-all
      background: #f3f4ff
      border: none
      font-size: 12px
      color: #704efd
      cursor: pointer
      padding: 4px 8px
      border-radius: 4px
      .dark &
        background: #374151
        color: #8b6eff

  &__ranking-item
    display: flex
    align-items: center
    gap: 8px
    cursor: pointer
    margin-bottom: 12px
    .filters__ranking-label
      transition: color 0.2s
    &.active .filters__ranking-label
      color: #704efd
      font-weight: 600
      .dark &
        color: #8b6eff
    &:hover .filters__ranking-label
      color: #704efd

  &__active-chips
    display: flex
    flex-wrap: wrap
    gap: 8px
    margin-bottom: 16px

  &__chip
    background: var(--text-color, #13013f)
    color: white
    padding: 4px 10px
    border-radius: 6px
    font-size: 11px
    display: inline-flex
    align-items: center
    gap: 6px
    .dark &
      background: #4b5563
    &-remove
      cursor: pointer
      font-weight: bold
      &:hover
        opacity: 0.7

  &__group
    margin-bottom: 16px
    &-title
      display: flex
      justify-content: space-between
      align-items: center
      cursor: pointer
      font-weight: 600
      margin-bottom: 8px
      color: var(--text-color, #13013f)
      .dark &
        color: #f3f4f6
    &-options
      display: flex
      flex-direction: column
      gap: 6px

  &__checkbox
    display: flex
    align-items: center
    gap: 6px
    cursor: pointer
    color: var(--text-muted, #13013f)
    .dark &
      color: #d1d5db
    input
      accent-color: #704efd
      .dark &
        accent-color: #8b6eff