.course-list
  width: 100%
  max-width: 1200px
  margin: 0 auto
  padding: 1rem
  font-family: inherit

  &__header
    display: flex
    flex-wrap: wrap
    justify-content: space-between
    align-items: center
    gap: 1rem
    margin-bottom: 1.5rem

  &__title
    font-size: 28px
    font-weight: 600
    line-height: 1.2
    color: #13013f
    .dark &
      color: #f3f4f6
    @media (max-width: 768px)
      font-size: 22px

  &__sort
    position: relative
    &-trigger
      display: flex
      align-items: center
      gap: 8px
      background: white
      border: 1px solid #d1d5db
      border-radius: 8px
      padding: 6px 12px
      font-size: 14px
      color: #13013f
      cursor: pointer
      transition: all 0.2s
      &:hover
        border-color: #704efd
        background: #f8f9ff
      .dark &
        background: #1f2937
        border-color: #4b5563
        color: #f3f4f6
        &:hover
          background: #374151
    &-dropdown
      position: absolute
      top: 100%
      right: 0
      margin-top: 8px
      min-width: 160px
      background: white
      border: 1px solid #e5e7eb
      border-radius: 8px
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1)
      z-index: 10
      .dark &
        background: #1f2937
        border-color: #4b5563
    &-option
      display: block
      width: 100%
      text-align: left
      padding: 8px 16px
      background: none
      border: none
      font-size: 14px
      cursor: pointer
      color: #13013f
      &:hover
        background: #f3f4ff
      .dark &
        color: #f3f4f6
        &:hover
          background: #374151

  &__search
    margin-bottom: 1.5rem
    &-box
      display: flex
      align-items: center
      gap: 8px
      background: white
      border: 1px solid #d1d5db
      border-radius: 8px
      padding: 8px 12px
      transition: border-color 0.2s
      &:focus-within
        border-color: #704efd
      .dark &
        background: #1f2937
        border-color: #4b5563
    &-icon
      flex-shrink: 0
      color: #9ca3af
    &-input
      flex: 1
      background: transparent
      border: none
      outline: none
      font-size: 14px
      color: #13013f
      .dark &
        color: #f3f4f6
      &::placeholder
        color: #9ca3af
    &-clear
      background: none
      border: none
      cursor: pointer
      color: #9ca3af
      &:hover
        color: #13013f
      .dark &:hover
        color: #f3f4f6

  &__grid
    display: grid
    grid-template-columns: 1fr
    gap: 20px
    max-height: 70vh
    overflow-y: auto
    padding-right: 8px
    @media (min-width: 768px)
      grid-template-columns: repeat(2, 1fr)
      max-height: 100vh
    @media (min-width: 1280px)
      grid-template-columns: repeat(3, 1fr)

  &__empty
    grid-column: 1 / -1
    text-align: center
    padding: 48px 24px
    background: white
    border: 1px dashed #d1d5db
    border-radius: 12px
    color: #6b7280
    .dark &
      background: #1f2937
      border-color: #4b5563
      color: #9ca3af

// Estilos de la tarjeta (course-card)
.course-card
  &__inner
    display: flex
    flex-direction: column
    overflow: hidden
    border-radius: 12px
    border: 1px solid #e5e7eb
    background: white
    transition: all 0.3s ease
    &:hover
      transform: translateY(-2px)
      border-color: rgba(112, 78, 253, 0.2)
      box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1)
    .dark &
      background: #1f2937
      border-color: #374151

  &__image-wrapper
    position: relative
    height: 176px
    overflow: hidden
    cursor: pointer
  &__image
    width: 100%
    height: 100%
    object-fit: cover
    transition: transform 0.5s
    .course-card:hover &
      transform: scale(1.05)

  &__live-badge
    position: absolute
    bottom: 12px
    right: 12px
    background: rgba(0,0,0,0.7)
    border-radius: 9999px
    padding: 4px 8px
    font-size: 11px
    color: white
    display: flex
    align-items: center
    gap: 4px
    &-dot
      width: 6px
      height: 6px
      background: #4ade80
      border-radius: 50%

  &__rating
    position: absolute
    bottom: 12px
    left: 12px
    background: rgba(0,0,0,0.7)
    border-radius: 9999px
    padding: 2px 8px
    font-size: 11px
    color: white
    display: flex
    align-items: center
    gap: 4px
    svg
      fill: #facc15
      color: #facc15

  &__content
    padding: 16px
    flex: 1
    display: flex
    flex-direction: column

  &__title
    font-size: 14px
    font-weight: 600
    line-height: 1.4
    margin-bottom: 8px
    color: #13013f
    display: -webkit-box
    -webkit-line-clamp: 3
    -webkit-box-orient: vertical
    overflow: hidden
    min-height: 3.9em
    .dark &
      color: #f3f4f6

  &__teacher
    display: flex
    align-items: center
    gap: 6px
    font-size: 12px
    color: #6b7280
    margin-bottom: 12px
    .dark &
      color: #9ca3af
    svg
      flex-shrink: 0

  &__date
    display: flex
    align-items: center
    gap: 6px
    font-size: 12px
    color: #6b7280
    margin-bottom: 8px
    flex-wrap: wrap
    .dark &
      color: #9ca3af
    &-in-progress
      color: #10b981
      margin-left: auto

  &__price-wrapper
    display: flex
    align-items: center
    gap: 8px
    margin-top: 4px
  &__discount
    background: #704efd
    color: white
    font-size: 11px
    font-weight: 600
    padding: 2px 6px
    border-radius: 4px
  &__price
    font-size: 14px
    font-weight: 600
    color: #13013f
    .dark &
      color: #f3f4f6
  &__original-price
    font-size: 12px
    color: #9ca3af
    text-decoration: line-through
    margin-top: 2px

  &__actions
    display: flex
    gap: 8px
    margin-top: 12px
  &__detail-btn
    flex: 1
    background: transparent
    border: 1px solid #704efd
    border-radius: 8px
    padding: 8px
    font-size: 13px
    font-weight: 600
    color: #13013f
    cursor: pointer
    transition: all 0.2s
    &:hover
      background: #704efd
      color: white
    .dark &
      color: #f3f4f6
      &:hover
        background: #704efd
        color: white
  &__cart-btn
    width: 48px
    background: #704efd
    border: none
    border-radius: 8px
    display: flex
    align-items: center
    justify-content: center
    cursor: pointer
    transition: background 0.2s
    &:hover
      background: #5a3dd4
    svg
      color: white