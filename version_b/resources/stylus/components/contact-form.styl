.contact-form-wrapper
  max-width: 28rem
  width: 100%
  margin: 0 auto
  padding: 50px 0

.contact-form
  background: white
  border-radius: 0.75rem
  padding: 1rem
  space-y: 1.5rem
  width: 100%

  @media (min-width: 768px)
    border: 1px solid #13013f
    padding: 2rem

  .dark &
    background: #1f2937
    @media (min-width: 768px)
      border-color: #4b5563

  &__header
    space-y: 0.5rem
    margin-bottom: 1.5rem

  &__title
    color: #13013f
    font-size: 1.25rem
    font-weight: 600
    margin-bottom: 0.5rem
    .dark &
      color: #f3f4f6

  &__description
    color: rgba(#13013f, 0.7)
    font-size: 0.875rem
    line-height: 1.5
    .dark &
      color: #9ca3af

  &__field
    margin-bottom: 1rem

  &__label
    display: block
    font-size: 0.875rem
    color: #13013f
    margin-bottom: 0.25rem
    .dark &
      color: #d1d5db

  &__required
    color: #ef4444

  &__input,
  &__textarea
    width: 100%
    background: white
    border: 1px solid #13013f
    border-radius: 0.375rem
    padding: 0.5rem 0.75rem
    color: #13013f
    outline: none
    transition: ring 0.2s
    font-size: 0.875rem

    &:focus
      ring: 2px solid #13013f

    .dark &
      background: #111827
      border-color: #4b5563
      color: #f3f4f6
      &:focus
        ring-color: #6b7280

  &__textarea
    height: 7rem
    resize: vertical

  &__message-footer
    display: flex
    justify-content: space-between
    margin-top: 0.25rem
    font-size: 0.75rem

  &__min-length
    color: rgba(#13013f, 0.6)
    .dark &
      color: #9ca3af

  &__counter
    color: rgba(#13013f, 0.6)
    .dark &
      color: #9ca3af

  &__error
    display: block
    color: #ef4444
    font-size: 0.75rem
    margin-top: 0.25rem

  &__submit
    width: 100%
    display: flex
    align-items: center
    justify-content: center
    gap: 0.5rem
    background: #7d61f1
    color: white
    padding: 0.5rem
    border-radius: 0.375rem
    border: none
    cursor: pointer
    transition: opacity 0.2s

    &:hover
      opacity: 0.9

    .dark &
      background: #5a3dd4

/* Estado de éxito (se genera dinámicamente por JS) */
.contact-form-success
  background: white
  border: 1px solid #13013f
  border-radius: 0.75rem
  padding: 2rem
  text-align: center
  max-width: 28rem
  width: 100%

  .dark &
    background: #1f2937
    border-color: #4b5563

  &__icon
    display: flex
    justify-content: center
    margin-bottom: 1rem
    .icon-circle
      background: #dcfce7
      padding: 1rem
      border-radius: 9999px
      border: 1px solid #86efac
      .dark &
        background: rgba(#064e3b, 0.5)
        border-color: #047857

  &__title
    color: #13013f
    font-size: 1.125rem
    font-weight: 600
    margin-bottom: 0.5rem
    .dark &
      color: #f3f4f6

  &__description
    color: rgba(#13013f, 0.7)
    margin-bottom: 1.5rem
    .dark &
      color: #9ca3af

  &__button
    background: none
    border: none
    color: #13013f
    cursor: pointer
    text-decoration: underline
    .dark &
      color: #d1d5db
      &:hover
        color: white