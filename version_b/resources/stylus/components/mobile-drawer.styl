.mobile-drawer
  position fixed
  inset 0
  z-index 1000
  display none

  &.is-open
    display block

  &__overlay
    position absolute
    inset 0
    background rgba(0,0,0,.5)
    opacity 0
    transition opacity .2s

  &__content
    position absolute
    top 0
    left 0
    width 86%
    max-width 24rem
    height 100%
    background var(--header-bg)
    transform translateX(-100%)
    transition transform .25s ease
    overflow-y auto
    padding 1.25rem
    box-shadow 0 25px 50px -12px rgba(0,0,0,.25)

  &.is-open &__overlay
    opacity 1

  &.is-open &__content
    transform translateX(0)

  /* header */
  &__header
    display flex
    justify-content space-between
    align-items center
    margin-bottom 1.25rem

    span
      font-weight 600
      color var(--text-color)

    button
      background none
      border 0
      font-size 22px
      cursor pointer
      color var(--text-color)

  /* whatsapp */
  &__whatsapp
    display flex
    align-items center
    gap .75rem
    margin-bottom 1rem
    color var(--text-color)

  /* sección */
  &__section
    margin 1.5rem 0

    &-title
      font-size .75rem
      font-weight 600
      text-transform uppercase
      letter-spacing .05em
      color #6b7280
      margin-bottom .5rem

      .dark &
        color #9ca3af

  /* links simples */
  &__links
    display flex
    flex-direction column
    gap .4rem

    a
      text-decoration none
      color var(--text-color)
      padding .25rem 0

      &:hover
        color var(--primary-color)

  /* grid inferior */
  &__grid
    display grid
    grid-template-columns 1fr
    gap .5rem
    margin-top 1rem

    a
      background #f3f4f6
      padding 12px 16px
      border-radius 8px
      text-decoration none
      font-weight 500
      color #13013f

      .dark &
        background #1f2937
        color #f9fafb

      &:hover
        background #e5e7eb

        .dark &
          background #374151